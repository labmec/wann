Cell[CellGroupData[{

Cell["\<\
If we use the flow as velocity, then the curves do not match at Re = 1187.38\
\>", "Subsection",
 CellChangeTimes->{{3.974279865310623*^9, 
  3.974279885908724*^9}},ExpressionUUID->"070af668-ce2e-4b65-8e65-\
711a7d064793"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"cfg", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Rho]", "->", "1000"}], ",", 
    RowBox[{"\[Mu]", "->", 
     SuperscriptBox["10", 
      RowBox[{"-", "3"}]]}], ",", 
    RowBox[{"Di", "->", "0.01"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"dpdx1", "=", 
  RowBox[{
   RowBox[{
    FractionBox["Q", "Clam"], "/.", 
    RowBox[{"{", 
     RowBox[{"Q", "->", 
      FractionBox[
       RowBox[{"R", " ", "\[Mu]"}], 
       RowBox[{"\[Rho]", " ", "Di"}]]}], "}"}]}], "/.", "cfg"}]}], "\[IndentingNewLine]", 
 RowBox[{"dpdx2", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["Q", "Cturb"], ")"}], 
     RowBox[{"7", "/", "4"}]], "/.", 
    RowBox[{"{", 
     RowBox[{"Q", "->", 
      FractionBox[
       RowBox[{"R", " ", "\[Mu]"}], 
       RowBox[{"\[Rho]", " ", "Di"}]]}], "}"}]}], "/.", "cfg"}]}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dpdx1", ",", "dpdx2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"R", ",", "0", ",", "2000"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"dpdx1", "==", "dpdx2"}], ",", "R"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9738646240442266`*^9, 3.973864642438758*^9}},
 CellLabel->"In[90]:=",ExpressionUUID->"fd865bfd-c362-4e17-903a-67d93302b3f1"],

