Notebook[{

Cell[CellGroupData[{
Cell["Analyzing the constitutive law for the wellbore", "Subsection",
 CellChangeTimes->{{3.973863935254847*^9, 
  3.9738639451939783`*^9}},ExpressionUUID->"8d38b230-42e7-4d33-9a27-\
c06c21ab9aee"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clam", "=", 
   FractionBox[
    RowBox[{"\[Pi]", " ", 
     SuperscriptBox["Di", "4"]}], 
    RowBox[{"128", " ", "\[Mu]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Q1", "=", 
  RowBox[{"Clam", " ", "dpdx"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Cturb", "=", 
   RowBox[{"2.252610888", " ", 
    FractionBox[
     SuperscriptBox["Di", 
      RowBox[{"19", "/", "7"}]], 
     RowBox[{
      SuperscriptBox["\[Mu]", 
       RowBox[{"1", "/", "7"}]], 
      SuperscriptBox["\[Rho]", 
       RowBox[{"3", "/", "7"}]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Q2", "=", 
  RowBox[{"Cturb", " ", 
   SuperscriptBox["dpdx", 
    RowBox[{"4", "/", "7"}]]}]}]}], "Input",
 CellChangeTimes->{{3.973857408371686*^9, 3.973857431690374*^9}, {
  3.9738576485086317`*^9, 3.9738576591966248`*^9}, {3.9738613042106867`*^9, 
  3.973861354926944*^9}, {3.9738638467733517`*^9, 3.973863890906901*^9}, {
  3.973863968724805*^9, 3.973863975692597*^9}},
 CellLabel->"In[96]:=",ExpressionUUID->"26e9fd09-8a17-44b9-a30a-30fbfab34c5d"],

Cell[CellGroupData[{

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["Di", "4"], " ", "dpdx", " ", "\[Pi]"}], 
  RowBox[{"128", " ", "\[Mu]"}]]], "Input",
 CellChangeTimes->{3.981115693252585*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"07730d8e-de07-4d0c-b8db-c25420d70f93"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["Di", "4"], " ", "dpdx", " ", "\[Pi]"}], 
  RowBox[{"128", " ", "\[Mu]"}]]], "Output",
 CellChangeTimes->{3.973864172955882*^9, 3.974279841199807*^9, 
  3.9811156936512737`*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"bf121355-efcc-40ac-b038-74fcb65948df"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Or, since Re = \[Rho] V D/\[Mu] and V = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"4", "Q"}], 
    RowBox[{"\[Pi]", " ", 
     SuperscriptBox["D", "2"]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d8435d0e-bcf1-4c6e-b68c-b12afb0536a1"],
 ", then Re = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"4", " ", "\[Rho]", " ", "Q"}], 
    RowBox[{"\[Pi]", " ", "D", " ", "\[Mu]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bfe98958-6b7c-46ed-adca-c8b985bcf2d5"],
 ". Isolating Q we get Q = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Pi]", " ", "D", " ", "\[Mu]", " ", "Re"}], 
    RowBox[{"4", " ", "\[Rho]"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "97afbd9e-4371-4cd8-b64a-6c481b4e3ad4"]
}], "Subsubsection",
 CellChangeTimes->{{3.973863977701724*^9, 3.973863977807487*^9}, {
  3.973864024620531*^9, 
  3.973864108049799*^9}},ExpressionUUID->"aa06a771-6d62-46c2-991f-\
55b9c0dea452"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"cfg", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Rho]", "->", "1000"}], ",", 
    RowBox[{"\[Mu]", "->", 
     SuperscriptBox["10", 
      RowBox[{"-", "3"}]]}], ",", 
    RowBox[{"Di", "->", "0.01"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"dpdx1", "=", 
  RowBox[{
   RowBox[{
    FractionBox["Q", "Clam"], "/.", 
    RowBox[{"{", 
     RowBox[{"Q", "->", 
      FractionBox[
       RowBox[{"\[Pi]", " ", "Di", " ", "\[Mu]", " ", "R"}], 
       RowBox[{"4", " ", "\[Rho]"}]]}], "}"}]}], "/.", "cfg"}]}], "\[IndentingNewLine]", 
 RowBox[{"dpdx2", "=", 
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox["Q", "Cturb"], ")"}], 
     RowBox[{"7", "/", "4"}]], "/.", 
    RowBox[{"{", 
     RowBox[{"Q", "->", 
      FractionBox[
       RowBox[{"\[Pi]", " ", "Di", " ", "\[Mu]", " ", "R"}], 
       RowBox[{"4", " ", "\[Rho]"}]]}], "}"}]}], "/.", "cfg"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"dpdx1", ",", "dpdx2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"R", ",", "0", ",", "2000"}], "}"}]}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"dpdx1", "==", "dpdx2"}], ",", "R"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9738639803171997`*^9, 3.9738640209166927`*^9}, {
  3.973864111660193*^9, 3.973864217285322*^9}, {3.9811164054298563`*^9, 
  3.981116522536421*^9}},
 CellLabel->"",ExpressionUUID->"cd41dc75-1ec9-42e6-82e7-fa025023aba0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\[Rho]", "\[Rule]", "1000"}], ",", 
   RowBox[{"\[Mu]", "\[Rule]", 
    FractionBox["1", "1000"]}], ",", 
   RowBox[{"Di", "\[Rule]", "0.01`"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.973864141323311*^9, 3.973864218983058*^9}, 
   3.974279847321102*^9},
 CellLabel->
  "Out[100]=",ExpressionUUID->"e8e68927-cfc0-4ffd-81dc-ff37085a2ef2"],

Cell[BoxData[
 RowBox[{"0.032`", " ", "R"}]], "Output",
